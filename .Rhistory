geom_vline(xintercept = 2020, linetype = "dashed", color = "darkred", linewidth = 1.2) +
# Add a text label right next to the event line
annotate("text", x = 2020.2, y = 12, label = "COVID-19 Lockdowns", color = "darkred ", fontface = "bold", hjust = 0) +
labs(
title = "Event Analysis: Impact of 2020 COVID-19 Lockdowns on Air Quality",
subtitle = "Annual population-weighted PM2.5 averages across the Netherlands",
x = "Year",
y = "Average Air Pollution (ug/m3)"
) +
scale_x_continuous(breaks = 2015:2023) + # Ensures every single year gets a label
theme_minimal()
str(raw_hospital_data)
head(raw_hospital_data$X2)
raw_hospital_data <- raw_hospital_data %>%
mutate(across(X2:X49, ~ as.numeric(gsub(",", ".", .)))) %>%
mutate(mean_hosp = rowMeans(across(X2:X49), na.rm = TRUE))
View(raw_hospital_data)
