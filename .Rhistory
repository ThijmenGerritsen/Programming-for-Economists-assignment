opnamen <- read_delim("data/Ziekenhuisopnamen__diagnose_indeling_VTV__regio_02062026_164323.csv",
delim = ";", escape_double = FALSE, trim_ws = TRUE,
skip = 3)
test<- combined_data
test$code <- test$`NUTS Code`
require(stringr)
#test <- test %>% filter(
#       str_detect(^NL(\\d{3}|\\d{2}[A-Z])$))
require(tidyverse)
length(test$code)
test <- test %>%
dplyr::filter(str_length(code) == 5
)
test <- test %>%
mutate(Year = as.numeric(year)) %>%
filter(Year > 2014)
