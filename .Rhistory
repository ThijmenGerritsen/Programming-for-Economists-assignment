require(ggplot2)
# Barplot
ggplot(combined_data, aes(x=year, y=`Air Pollution Population Weighted Average [ug/m3]`)) +
geom_bar(stat = "summary", fun = "mean",
fill = "lightpink",
colour = "purple") +
geom_smooth(method = "lm", color = "blue", linewidth = 1) +
labs(
